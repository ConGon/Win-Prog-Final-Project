<UserControl x:Class="Final_Project_IMDB.Views.TitleDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="20">

            <!-- Title -->
            <TextBlock Text="{Binding SelectedTitle.PrimaryTitle}"
               FontSize="22"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

            <!-- Rating -->
            <TextBlock Text="{Binding AverageRating, StringFormat=Rating: {0:F1}/10}"
               FontSize="16"
               Margin="0,0,0,5"/>

            <TextBlock Text="{Binding NumVotes, StringFormat=Votes: {0:N0}}"
               FontSize="14"
               Margin="0,0,0,10"/>

            <!-- Genres -->
<TextBlock Text="Genres"
           FontSize="18"
           FontWeight="Bold"
           Margin="0,10,0,5"/>

<ItemsControl ItemsSource="{Binding Genres}">
    <ItemsControl.ItemTemplate>
        <DataTemplate>
            <TextBlock Text="{Binding Name}" />
        </DataTemplate>
    </ItemsControl.ItemTemplate>
</ItemsControl>

            <TextBlock Text="Cast"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,10,0,5"/>

            <!-- Cast -->
            <ItemsControl ItemsSource="{Binding Cast}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding PrimaryName}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Back Button -->
            <Button Content="Back"
            Command="{Binding BackCommand}"
            Width="100"
            Margin="0,20,0,0"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>