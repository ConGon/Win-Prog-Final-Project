<UserControl x:Class="Final_Project_IMDB.Views.ActorDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="20">

            <!-- Back -->
            <Button Content="← Back"
                    Command="{Binding BackCommand}"
                    Width="100"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,15"/>

            <!-- Actor name -->
            <TextBlock Text="{Binding SelectedActor.PrimaryName}"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,0,0,5"/>

            <!-- Profession (FIXED) -->
            <TextBlock Text="{Binding FormattedProfession}"
                       Foreground="Gray"
                       Margin="0,0,0,20"/>

            <!-- Known For -->
            <TextBlock Text="Known For"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <ItemsControl ItemsSource="{Binding KnownFor}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Button Command="{Binding DataContext.OpenTitleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Margin="0,5"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalContentAlignment="Left">

                            <TextBlock Text="{Binding PrimaryTitle}"
                                       FontWeight="Bold"/>

                        </Button>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>

    </ScrollViewer>

</UserControl>