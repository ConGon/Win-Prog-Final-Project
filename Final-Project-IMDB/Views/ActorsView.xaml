<UserControl x:Class="Final_Project_IMDB.Views.ActorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="10">

            <TextBlock Text="Actors"
                       FontSize="18"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

        </StackPanel>

        <!-- List -->
        <ScrollViewer Grid.Row="1">

            <ItemsControl ItemsSource="{Binding Actors}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border Margin="5"
                                Padding="5"
                                Background="#222"
                                CornerRadius="5">

                            <Button Content="{Binding PrimaryName}"
                                    Command="{Binding DataContext.SelectActorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="White"
                                    Padding="8"/>
                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </ScrollViewer>

        <!-- Pagination -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">

            <Button Content="Prev"
                    Command="{Binding PrevPageCommand}"
                    Width="80"
                    Margin="5"/>

            <Button Content="Next"
                    Command="{Binding NextPageCommand}"
                    Width="80"
                    Margin="5"/>

        </StackPanel>

    </Grid>

</UserControl>